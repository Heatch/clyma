NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=
NEXT_PUBLIC_PROGRAM_ID=
DATABASE_URL=

# Server-only. Used to generate climate markets via the Gemini API.
# Get a key at https://aistudio.google.com/apikey (new keys use the "AQ." format).
# The app generates through the Interactions API, which has free-tier quota on
# current keys. If generation fails, the app falls back to bundled sample markets.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
# How many markets to generate (default 24, max 40).
GEMINI_MARKET_COUNT=24
